{
    "id": "epg-enricher",
    "name": "EPG Enricher",
    "version": "1.1.1",
    "api_version": "1.0.0",
    "description": "Enriches EPG programme data with TMDB artwork (posters, backdrops), genres and descriptions. Only processes channels that are mapped in your playlists, complementing existing Schedules Direct / Gracenote metadata where data is missing.",
    "entrypoint": "Plugin.php",
    "class": "AppLocalPlugins\\EpgEnricher\\Plugin",
    "capabilities": [
        "epg_processor"
    ],
    "hooks": [
        "epg.cache.generated"
    ],
    "permissions": [
        "db_read",
        "filesystem_read",
        "filesystem_write",
        "network_egress",
        "hook_subscriptions",
        "queue_jobs"
    ],
    "settings": [
        {
            "id": "enrich_from_tmdb",
            "type": "boolean",
            "label": "Enrich programmes with TMDB data",
            "default": true,
            "helper_text": "Fetch posters, backdrops, genres and descriptions from TMDB for programmes that are missing artwork."
        },
        {
            "id": "overwrite_existing",
            "type": "boolean",
            "label": "Overwrite existing metadata",
            "default": false,
            "helper_text": "Replace existing artwork and descriptions even if the programme already has data (e.g. from Schedules Direct)."
        },
        {
            "id": "enrich_categories",
            "type": "boolean",
            "label": "Enrich missing categories/genres",
            "default": true,
            "helper_text": "Fill in missing genre/category from TMDB when the programme has none."
        },
        {
            "id": "enrich_descriptions",
            "type": "boolean",
            "label": "Enrich missing descriptions",
            "default": true,
            "helper_text": "Fill in missing programme descriptions from TMDB."
        },
        {
            "id": "auto_run_on_cache",
            "type": "boolean",
            "label": "Auto-run after EPG cache generation",
            "default": true,
            "helper_text": "Automatically enrich EPG data whenever the cache is rebuilt."
        }
    ],
    "actions": [
        {
            "id": "enrich_epg",
            "label": "Enrich EPG",
            "icon": "heroicon-o-sparkles",
            "requires_confirmation": true,
            "fields": [
                {
                    "id": "epg_id",
                    "type": "model_select",
                    "label": "EPG Source",
                    "model": "App\\Models\\Epg",
                    "scope": "owned",
                    "required": true
                },
                {
                    "id": "playlist_id",
                    "type": "model_select",
                    "label": "Playlist (optional - leave empty for all)",
                    "model": "App\\Models\\Playlist",
                    "scope": "owned",
                    "required": false
                }
            ]
        },
        {
            "id": "health_check",
            "label": "Health Check",
            "icon": "heroicon-o-heart",
            "dry_run": true,
            "fields": []
        }
    ],
    "data_ownership": {
        "directories": [
            "plugin-data/epg-enricher"
        ],
        "tables": [],
        "files": [],
        "default_cleanup_policy": "preserve"
    }
}
